# ── External data APIs ──

# YouTube Data API v3 — required for /discover tutorial videos.
# Get a free key: Google Cloud Console → enable "YouTube Data API v3" → Credentials.
# Free quota is small (~100 searches/day) — results are cached aggressively.
YOUTUBE_API_KEY=

# Spoonacular — required for /discover recipes and /recipe/[id] details.
# Get a free key: https://spoonacular.com/food-api (free tier ~150 points/day).
SPOONACULAR_API_KEY=

# ── LLM provider (used by the "Ask PantryChef" RAG feature — see Milestone 5) ──
# groq | anthropic | openai
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Required if LLM_PROVIDER=groq — free tier, safe default for a public demo.
GROQ_API_KEY=

# Required if LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Required if LLM_PROVIDER=openai.
OPENAI_API_KEY=

# ── App config ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Open Food Facts requires no API key, but fair-use guidance asks for a
# descriptive User-Agent identifying your app instance.
OPEN_FOOD_FACTS_USER_AGENT=PantryChef/1.0 (https://github.com/<you>/pantrychef)
